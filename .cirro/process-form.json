{
  "form": {
    "title": "nf-core/alarmist pipeline parameters",
    "description": "Assessment of Ligand And Receptor Interaction Motifs In Spatial Transcriptomics",
    "type": "object",
    "properties": {
      "patchify_options": {
        "title": "Patchify options",
        "type": "object",
        "fa_icon": "fas fa-th",
        "description": "Configure spatial patchification parameters",
        "properties": {
          "patch_size": {
            "type": "integer",
            "default": 50,
            "description": "Patch size in micrometers",
            "fa_icon": "fas fa-ruler",
            "minimum": 10,
            "maximum": 500
          },
          "cell_type_column": {
            "type": "string",
            "default": "cell_type",
            "description": "Column name for cell type annotations in adata.obs",
            "fa_icon": "fas fa-tag"
          },
          "resource": {
            "type": "string",
            "default": "cellphonedb",
            "description": "Ligand-receptor interaction database",
            "fa_icon": "fas fa-database",
            "enum": ["cellphonedb", "cellchatdb"]
          }
        }
      },
      "bptf_options": {
        "title": "BPTF options",
        "type": "object",
        "fa_icon": "fas fa-project-diagram",
        "description": "Configure BPTF matrix factorization parameters",
        "properties": {
          "n_components": {
            "type": "integer",
            "default": 15,
            "description": "Number of latent motifs to discover",
            "fa_icon": "fas fa-layer-group",
            "minimum": 2,
            "maximum": 100
          },
          "max_iter": {
            "type": "integer",
            "default": 200,
            "description": "Maximum iterations for BPTF optimization",
            "fa_icon": "fas fa-redo",
            "minimum": 50,
            "maximum": 1000
          },
          "seed": {
            "type": "integer",
            "default": 42,
            "description": "Random seed for reproducibility",
            "fa_icon": "fas fa-dice"
          }
        }
      },
      "glm_options": {
        "title": "GLM options",
        "type": "object",
        "fa_icon": "fas fa-chart-bar",
        "description": "Configure GLM differential expression analysis",
        "properties": {
          "condition_column": {
            "type": "string",
            "description": "Column in adata.obs for condition comparison (optional)",
            "fa_icon": "fas fa-columns"
          }
        }
      },
      "input_output_options": {
        "title": "Input/output options",
        "type": "object",
        "fa_icon": "fas fa-terminal",
        "description": "Define where the pipeline should find input data and save output data.",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address for completion summary.",
            "fa_icon": "fas fa-envelope",
            "pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$"
          },
          "multiqc_title": {
            "type": "string",
            "description": "MultiQC report title.",
            "fa_icon": "fas fa-file-signature"
          }
        }
      },
      "generic_options": {
        "title": "Generic options",
        "type": "object",
        "fa_icon": "fas fa-cogs",
        "description": "Less common options for the pipeline.",
        "properties": {
          "publish_dir_mode": {
            "type": "string",
            "default": "copy",
            "description": "Method used to save pipeline results.",
            "fa_icon": "fas fa-copy",
            "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"],
            "hidden": true
          },
          "validate_params": {
            "type": "boolean",
            "default": true,
            "description": "Validate parameters against schema at runtime",
            "fa_icon": "fas fa-check-square",
            "hidden": true
          }
        }
      }
    }
  },
  "ui": {}
}
